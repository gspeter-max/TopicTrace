
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# LLM API key (OpenAI-compatible provider)
LLM_API_KEY=your-llm-api-key-here

# Tavily Search API key (https://tavily.com)
TAVILY_API_KEY=your-tavily-api-key-here
# Neo4j Docker — environment variable template
# Copy these values into your project root .env file
# Do NOT commit your real .env file

# ── Neo4j connection (used by the Python app) ──────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_strong_password_here

# ── Notes ──────────────────────────────────────────────────────────────────────
# NEO4J_URI    → use bolt:// for local Docker (NOT neo4j+s:// which is TLS-only cloud)
# NEO4J_USER   → must match the username in docker-compose.yml NEO4J_AUTH
# NEO4J_PASSWORD → choose something strong; must be at least 8 characters

LLAMA_PARSE_APIKEY=llama-parse-api_key
JINA_API_KEY=jina_api_key
VOYAGE_API_KEY=VOYAGE_API_KEY
MISTRAL_API_KEY=mistral_api_key 